generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  availability     MentorAvailability[]
  interviews       Interview[]          @relation("UserInterviews")
  mentorInterviews Interview[]          @relation("MentorInterviews")

  @@index([role])
}

model Interview {
  id           String    @id @default(cuid())
  topic        String
  date         DateTime
  status       Status    @default(PENDING)
  userId       String
  mentorId     String?
  rating       Int?
  feedback     String?
  strengths    String?
  improvements String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User  @relation("UserInterviews", fields: [userId], references: [id], onDelete: Cascade)
  mentor User? @relation("MentorInterviews", fields: [mentorId], references: [id], onDelete: SetNull)

  @@index([mentorId, date])
  @@index([userId, date])
  @@index([status])
}

model MentorAvailability {
  id        String @id @default(cuid())
  mentorId  String
  dayOfWeek Int
  startHour Int
  endHour   Int

  mentor User @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([mentorId, dayOfWeek])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STUDENT
  MENTOR
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}